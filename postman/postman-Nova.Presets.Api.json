              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"target_user_id\": \"{{target_user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\"\n}"
            },
            "description": "Admin-only. Sets the target user's password to the default (changeMe@ddMMM, e.g. changeMe@11Apr) hashed via Argon2id. Also sets must_change_password = true, clears failed_login_count and locked_until. target_user_id is the user whose password is being reset \u2014 distinct from user_id (the calling admin). Target user must have an active profile."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"message\": \"Default password set. User must change password on next login.\"\n}"
            },
