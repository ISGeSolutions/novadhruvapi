    {
      "name": "Group Tour Lookups (moved from OpsGroups)",
      "description": "User-list and Tour Generic catalogue lookups previously hosted on Nova.OpsGroups.Api. Moved here on 2026-04-19 — frontend callers reference the same endpoint registry key, only the SERVICE_MAP entry + path changed. Backend handoff: docs/backend-handoff-opsadmin-views-and-summary.md.",
      "item": [
        {
          "name": "Fetch Users by Role (was: grouptour-task-team-members)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/users/by-role",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "by-role"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"roles\": [\"ops_manager\", \"ops_exec\"],\n  \"branch_code_filter\": null\n}"
            },
            "description": "Fetch users by role (e.g. ops_manager, ops_exec). Replaces /api/v1/grouptour-task-team-members on Nova.OpsGroups.Api. Roles are resolved against the tenant's role catalogue. Optional branch_code_filter narrows to specific branches."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"members\": [\n    {\n      \"user_id\": \"user-1\",\n      \"name\": \"Sarah Mitchell\",\n      \"initials\": \"SM\",\n      \"email\": \"sarah@example.com\",\n      \"phone\": \"+44 20 7946 0011\",\n      \"avatar_url\": \"https://cdn.novadhruv.com/avatars/user-1.jpg\",\n      \"roles\": [\"ops_manager\"],\n      \"is_active\": true\n    },\n    {\n      \"user_id\": \"user-4\",\n      \"name\": \"Jo Chen\",\n      \"initials\": \"JC\",\n      \"email\": \"jo@example.com\",\n      \"phone\": null,\n      \"avatar_url\": null,\n      \"roles\": [\"ops_manager\", \"ops_exec\"],\n      \"is_active\": true\n    }\n  ]\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"unauthorized\",\n  \"message\": \"Missing or expired token\"\n}"
            }
          ]
        },
        {
          "name": "Fetch Tour Generics catalogue (was: grouptour-task-tour-generics)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/groups/tour-generics",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "groups", "tour-generics"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\"\n}"
            },
            "description": "Fetch the full Tour Generic catalogue for the tenant. Replaces /api/v1/grouptour-task-tour-generics on Nova.OpsGroups.Api. Used by SLA hierarchy editor + filter dropdowns. Switch to /groups/tour-generics/search if catalogue exceeds ~2000 entries."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"tour_generics\": [\n    { \"code\": \"BHU\", \"name\": \"Bhutan\" },\n    { \"code\": \"NORFJORD\", \"name\": \"Norwegian Fjords\" },\n    { \"code\": \"NEPAL\", \"name\": \"Nepal\" }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Search Tour Generics — typeahead (was: group-task-tour-generics-search)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/groups/tour-generics/search",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "groups", "tour-generics", "search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"query\": \"BHU\",\n  \"field\": \"code\",\n  \"limit\": 8\n}"
            },
            "description": "Typeahead search over the Tour Generic catalogue. Replaces /api/v1/group-task-tour-generics-search on Nova.OpsGroups.Api. field=name|code, query is a fuzzy match. Returns up to `limit` results."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"results\": [\n    { \"code\": \"BHU\", \"name\": \"Bhutan\" },\n    { \"code\": \"BHX\", \"name\": \"Bhutan Express\" }\n  ]\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "Task List catalogue (relocated from Nova.OpsGroups.Api). Backed by a single Presets table; columns: code (PK, e.g. VISA), name, required_ind, critical_ind, frz_ind, plus audit columns. Path param is {code} — the human-readable stable key, also used in SLA rules and the reorder body.",
      "item": [
        {
          "name": "Fetch Tasks",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"include_frozen\": false\n}"
            },
            "description": "Fetch the Task List catalogue. Optional `include_frozen` (boolean, default false) returns frozen rows as well. Rows are sorted by `sort_order` ascending; rows with NULL sort_order sort last."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"tasks\": [\n    {\n      \"code\": \"VISA\",\n      \"name\": \"Visa Check\",\n      \"required_ind\": true,\n      \"critical_ind\": true,\n      \"frz_ind\": false,\n      \"sort_order\": 1,\n      \"updated_at\": \"2026-03-18T14:40:00.000Z\",\n      \"updated_by\": \"U001\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Save Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{code}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{code}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"name\": \"Visa Check\",\n  \"required_ind\": true,\n  \"critical_ind\": true,\n  \"frz_ind\": false\n}"
            },
            "description": "Update a task definition. Path param `{code}` is the stable human-readable key (e.g. VISA). Does NOT mutate `sort_order` — use the reorder endpoint for that."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": \"VISA\",\n  \"name\": \"Visa Check\",\n  \"required_ind\": true,\n  \"critical_ind\": true,\n  \"frz_ind\": false,\n  \"updated_at\": \"2026-04-19T10:00:00.000Z\",\n  \"updated_by\": \"U001\"\n}"
            }
          ]
        },
        {
          "name": "Reorder Tasks",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/reorder",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "reorder"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"order\": [\n    { \"code\": \"VISA\", \"sort_order\": 1 },\n    { \"code\": \"FLIGHT\", \"sort_order\": 2 },\n    { \"code\": \"HOTEL\", \"sort_order\": 3 }\n  ]\n}"
            },
            "description": "Persist a new manual display order for the Task List. Apply atomically (single transaction). `sort_order` is 1-based. Codes not in the payload are left untouched. Returns 409 with `unknown_codes` if any code does not exist."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true\n}"
            },
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"type\": \"https://api.novadhruv.com/errors/unknown-task-code\",\n  \"title\": \"Unknown task code\",\n  \"status\": 409,\n  \"detail\": \"One or more codes in the order payload do not exist.\",\n  \"unknown_codes\": [\"XYZ\"]\n}"
            }
          ]
        }
      ]
    }
  ]
}
