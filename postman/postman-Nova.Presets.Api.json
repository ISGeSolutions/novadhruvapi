{
  "info": {
    "name": "Nova.Presets.Api",
    "description": "User profile, branches, access levels and lookup lists",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5103",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// -----------------------------------------------------------------------",
          "// Nova.Presets.Api \u2014 Auto JWT",
          "// Generates a fresh HS256 token if none exists or the existing one is",
          "// within 60 seconds of expiry. Reads from environment / collection vars.",
          "// Required variables: jwt_secret, tenant_id, company_code, branch_code, user_id",
          "// Optional variables: jwt_issuer (default: https://auth.nova.internal)",
          "//                     jwt_audience (default: nova-api)",
          "// -----------------------------------------------------------------------",
          "",
          "// Skip token generation for anonymous endpoints.",
          "const url = pm.request.url.toString();",
          "if (url.includes('/hello') || url.includes('/health') || url.includes('/confirm-password-change')) {",
          "    return;",
          "}",
          "",
          "// Reuse the existing token if it is still valid (60 s buffer).",
          "const existing = pm.variables.get('access_token');",
          "if (existing) {",
          "    try {",
          "        const parts = existing.split('.');",
          "        if (parts.length === 3) {",
          "            const padded  = parts[1].replace(/-/g, '+').replace(/_/g, '/');",
          "            const decoded = JSON.parse(CryptoJS.enc.Utf8.stringify(",
          "                CryptoJS.enc.Base64.parse(padded)",
          "            ));",
          "            const now = Math.floor(Date.now() / 1000);",
          "            if (decoded.exp && decoded.exp > now + 60) {",
          "                console.log('[Nova.Presets] access_token still valid \u2014 skipping refresh.');",
          "                return;",
          "            }",
          "        }",
          "    } catch (_) { /* malformed token \u2014 fall through to regenerate */ }",
          "}",
          "",
          "// Validate required variables are present.",
          "const required = ['jwt_secret', 'tenant_id', 'company_code', 'branch_code', 'user_id'];",
          "for (const key of required) {",
          "    if (!pm.variables.get(key)) {",
          "        throw new Error('[Nova.Presets] Missing variable: ' + key +",
          "            '. Add it to your active environment or collection variables.');",
          "    }",
          "}",
          "",
          "// Build and sign the JWT.",
          "const base64url = (obj) =>",
          "    CryptoJS.enc.Base64",
          "        .stringify(CryptoJS.enc.Utf8.parse(JSON.stringify(obj)))",
          "        .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
          "",
          "const now = Math.floor(Date.now() / 1000);",
          "",
          "const header  = base64url({ alg: 'HS256', typ: 'JWT' });",
          "const payload = base64url({",
          "    iss:        pm.variables.get('jwt_issuer')   || 'https://auth.nova.internal',",
          "    aud:        pm.variables.get('jwt_audience') || 'nova-api',",
          "    sub:        pm.variables.get('user_id'),",
          "    tenant_id:  pm.variables.get('tenant_id'),",
          "    company_code: pm.variables.get('company_code'),",
          "    branch_code:  pm.variables.get('branch_code'),",
          "    user_id:    pm.variables.get('user_id'),",
          "    iat: now,",
          "    exp: now + 3600",
          "});",
          "",
          "const signingInput = header + '.' + payload;",
          "const rawSig       = CryptoJS.HmacSHA256(signingInput, pm.variables.get('jwt_secret'));",
          "const signature    = CryptoJS.enc.Base64.stringify(rawSig)",
          "    .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
          "",
          "const token = signingInput + '.' + signature;",
          "",
          "// Write to collection variables (takes precedence over globals).",
          "// Also write to environment if one is active.",
          "pm.collectionVariables.set('access_token', token);",
          "try { pm.environment.set('access_token', token); } catch (_) {}",
          "",
          "console.log('[Nova.Presets] access_token refreshed.');",
          "console.log('  tenant_id: ' + pm.variables.get('tenant_id'));",
          "console.log('  user_id:   ' + pm.variables.get('user_id'));",
          "console.log('  expires:   ' + new Date((now + 3600) * 1000).toISOString());"
        ]
      }
    }
  ],
