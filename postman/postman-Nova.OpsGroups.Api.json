            "body": { "mode": "raw", "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"updates\": [\n    { \"departure_id\": \"DEP-001\", \"group_task_id\": \"GT-001\", \"old_status\": \"not_started\", \"new_status\": \"in_progress\", \"notes\": null },\n    { \"departure_id\": \"DEP-001\", \"group_task_id\": \"GT-002\", \"old_status\": \"in_progress\",  \"new_status\": \"complete\",     \"notes\": \"Done\" }\n  ]\n}" },
            "description": "Optimistic bulk update — all-or-nothing. If ANY item has old_status mismatch the entire transaction rolls back and 409 is returned with a results[] array showing which items conflicted."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": "{\n  \"success\": true,\n  \"updated_count\": 2,\n  \"results\": [\n    { \"group_task_id\": \"GT-001\", \"success\": true,  \"new_status\": \"in_progress\" },\n    { \"group_task_id\": \"GT-002\", \"success\": true,  \"new_status\": \"complete\" }\n  ]\n}" },
