{
  "info": {
    "name": "Nova.OpsGroups.Api",
    "description": "Operations Groups API — departures, group tasks, SLA rules, SLA hierarchy, business rules, and dashboard. All request bodies include 7 auto-injected RequestContext fields.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5106", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const url = pm.request.url.toString();",
          "if (url.includes('/hello') || url.includes('/health')) return;",
          "const existing = pm.variables.get('access_token');",
          "if (existing) {",
          "    try {",
          "        const parts = existing.split('.');",
          "        if (parts.length === 3) {",
          "            const padded  = parts[1].replace(/-/g, '+').replace(/_/g, '/');",
          "            const decoded = JSON.parse(CryptoJS.enc.Utf8.stringify(CryptoJS.enc.Base64.parse(padded)));",
          "            const now = Math.floor(Date.now() / 1000);",
          "            if (decoded.exp && decoded.exp > now + 60) { return; }",
          "        }",
          "    } catch (_) {}",
          "}",
          "const required = ['jwt_secret', 'tenant_id', 'company_code', 'branch_code', 'user_id'];",
          "for (const key of required) {",
          "    if (!pm.variables.get(key)) throw new Error('[Nova.OpsGroups] Missing variable: ' + key);",
          "}",
          "const base64url = (obj) => CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(JSON.stringify(obj))).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
          "const now = Math.floor(Date.now() / 1000);",
          "const header  = base64url({ alg: 'HS256', typ: 'JWT' });",
          "const payload = base64url({ iss: pm.variables.get('jwt_issuer') || 'https://auth.nova.internal', aud: pm.variables.get('jwt_audience') || 'nova-api', sub: pm.variables.get('user_id'), tenant_id: pm.variables.get('tenant_id'), company_code: pm.variables.get('company_code'), branch_code: pm.variables.get('branch_code'), user_id: pm.variables.get('user_id'), iat: now, exp: now + 3600 });",
          "const sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(header + '.' + payload, pm.variables.get('jwt_secret'))).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
          "const token = header + '.' + payload + '.' + sig;",
          "pm.collectionVariables.set('access_token', token);",
          "try { pm.environment.set('access_token', token); } catch (_) {}",
          "console.log('[Nova.OpsGroups] access_token refreshed.');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Departures",
      "item": [
        {
