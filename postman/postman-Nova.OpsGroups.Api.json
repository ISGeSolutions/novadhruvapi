            "url": { "raw": "{{base_url}}/api/v1/grouptour-task-departures", "host": ["{{base_url}}"], "path": ["api","v1","grouptour-task-departures"] },
            "body": { "mode": "raw", "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"company_code\": \"{{company_code}}\",\n  \"branch_code\": \"{{branch_code}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"browser_locale\": \"en-GB\",\n  \"browser_timezone\": \"Europe/London\",\n  \"ip_address\": \"203.0.113.42\",\n  \"date_from\": \"2026-03-01\",\n  \"date_to\": \"2026-09-30\",\n  \"series_code\": null,\n  \"destination_code\": null,\n  \"branch_code_filter\": null,\n  \"ops_manager\": null,\n  \"ops_exec\": null,\n  \"search\": null,\n  \"ignore_complete\": false,\n  \"projection\": \"full\",\n  \"page\": 1,\n  \"page_size\": 50\n}" },
            "description": "Paginated departure list. projection: 'full' | 'tasks' | 'calendar'. ignore_complete=true hides fully-complete departures. ops_manager/ops_exec filter by initials."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": "{\n  \"departures\": [\n    {\n      \"departure_id\": \"DEP-001\",\n      \"series_code\": \"NORFJORD\",\n      \"series_name\": \"Norwegian Fjords Explorer\",\n      \"departure_date\": \"2026-06-15\",\n      \"return_date\": \"2026-06-22\",\n      \"destination_code\": \"NO\",\n      \"destination_name\": \"Norway\",\n      \"branch_code\": \"SYD\",\n      \"pax_count\": 28,\n      \"booking_count\": 14,\n      \"ops_manager\": \"SM\",\n      \"ops_exec\": \"TB\",\n      \"gtd\": false,\n      \"notes\": null,\n      \"group_tasks\": [\n        { \"group_task_id\": \"GT-001\", \"template_code\": \"VISA\", \"status\": \"complete\", \"due_date\": \"2026-05-15\", \"completed_date\": \"2026-05-10\", \"notes\": null, \"source\": \"GLOBAL\" }\n      ],\n      \"readiness_pct\": 75,\n      \"risk_level\": \"amber\"\n    }\n  ],\n  \"total\": 42,\n  \"page\": 1,\n  \"page_size\": 50\n}" },
            { "name": "403 Forbidden", "status": "Forbidden", "code": 403, "header": [{ "key": "Content-Type", "value": "application/problem+json" }], "body": "{ \"title\": \"Forbidden\", \"status\": 403, \"detail\": \"tenant_id does not match the authenticated tenant.\" }" },
            { "name": "422 Validation", "status": "Unprocessable Entity", "code": 422, "header": [{ "key": "Content-Type", "value": "application/problem+json" }], "body": "{ \"title\": \"Validation failed\", \"status\": 422, \"errors\": { \"tenant_id\": [\"Required\"] } }" }
          ]
        },
        {
