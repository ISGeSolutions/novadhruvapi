{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nova AppHost (Aspire)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/host/Nova.AppHost/Nova.AppHost.csproj",
      "launchSettingsProfile": "http"
    },
    {
      "name": "Nova.Shell.Api (HTTP)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/services/Nova.Shell.Api/Nova.Shell.Api.csproj",
      "launchSettingsProfile": "Nova.Shell.Api (HTTP)"
    },
    {
      "name": "Nova.Shell.Api (HTTPS)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/services/Nova.Shell.Api/Nova.Shell.Api.csproj",
      "launchSettingsProfile": "Nova.Shell.Api (HTTPS)"
    },
    {
      "name": "Nova.Shell.Api (Console)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/services/Nova.Shell.Api/Nova.Shell.Api.csproj",
      "launchSettingsProfile": "Nova.Shell.Api (Console)"
    },
    {
      "type": "aspire",
      "request": "launch",
      "name": "Aspire: Launch default AppHost",
      "program": "${workspaceFolder}"
    }
  ]
}