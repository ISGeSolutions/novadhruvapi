{
  "info": {
    "name": "Nova.Shell.Api — Mock Server",
    "description": "Mock server collection for Nova.Shell.Api. Import this collection into Postman, then create a Mock Server from it. Postman matches incoming requests to the saved examples and returns the corresponding response.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://<your-mock-id>.mock.pstmn.io",
      "type": "string",
      "description": "Replace with the Mock Server URL generated by Postman after creating the mock."
    }
  ],
