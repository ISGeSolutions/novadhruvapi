{
  "Logging": {
    "DefaultLevel": "Debug",
    "EnableRequestResponseLogging": false,
    "EnableDiagnosticLogging": false,
    "Windows": [
      { "Name": "PeakMorning",     "Start": "07:00", "End": "10:00", "Level": "Warning" },
      { "Name": "DiagnosticNight", "Start": "22:00", "End": "02:00", "Level": "Debug"   }
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "OutboxRelay": {
    "Enabled": false,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50
  },
  "SqlLogging": {
    "Enabled": true,
    "LogLevel": "Debug",
    "IncludeParameters": true
  },
  "Caching": {
    "GloballyEnabled": false,
    "EmergencyDisable": false,
    "DryRunMode": false,
    "Profiles": {
      "ReferenceData":   { "Layer": "None", "TtlSeconds": 0, "Enabled": false },
      "TransactionData": { "Layer": "None", "TtlSeconds": 0, "Enabled": false }
    },
    "EndpointExclusions": []
  },
  "ChangePassword": {
    "TokenExpiryMinutes": 60
  },
  "Email": {
    "Provider": "SendGrid",
    "SendGrid": {
      "SenderAddress": "noreply@novaplatform.io",
      "SenderDisplayName": "Nova Platform"
    }
  }
}
