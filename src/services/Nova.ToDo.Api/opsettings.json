{
  "Logging": {
    "DefaultLevel": "Information",
    "EnableRequestResponseLogging": false,
    "EnableDiagnosticLogging": false,
    "Windows": [
      { "Name": "PeakMorning",     "Start": "07:00", "End": "10:00", "Level": "Warning" },
      { "Name": "DiagnosticNight", "Start": "22:00", "End": "02:00", "Level": "Debug"   }
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "OutboxRelay": {
    "Enabled": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50
  },
  "Caching": {
    "GloballyEnabled": true,
    "EmergencyDisable": false,
    "DryRunMode": false,
    "Profiles": {
      "ReferenceData":   { "Layer": "Redis", "TtlSeconds": 3600, "Enabled": true  },
      "TransactionData": { "Layer": "None",  "TtlSeconds": 0,    "Enabled": false }
    },
    "EndpointExclusions": []
  },
  "ConcurrencyCheck": {
    "StrictMode": true,
    "ConflictMessage": "Record was updated between your read and update. Refresh data."
  },
  "ToDoSummary": {
    "ClientCompletedWindowDays": 15,
    "SupplierCompletedWindowDays": 30
  }
}
